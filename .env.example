# EMDR Platform Environment Variables
# Copy this file to .env.local and fill in your API keys

# Anthropic Claude API (Clinical Reasoning Engine)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Database
DATABASE_URL=postgresql://localhost:5432/emdr_platform

# Authentication
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Session Configuration
SESSION_MAX_DURATION_MINUTES=90
SESSION_CLOSURE_WARNING_MINUTES=15

# Safety Configuration
SAFETY_CRISIS_HOTLINE=988
SAFETY_AUTO_ESCALATION=true
SAFETY_SUPERVISION_TIER=full  # full | async | autonomous
